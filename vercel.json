{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://assetflow-erp-vm62.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://assetflow-erp-vm62.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
